name = "bokeh-gallery-hearts"
main = "worker.js"
compatibility_date = "2026-05-11"

[vars]
ALLOWED_ORIGINS = "https://bokeh.dog,https://bokehcoyote.github.io,http://localhost:4173,http://127.0.0.1:4173"

[[durable_objects.bindings]]
name = "HEART_COUNTERS"
class_name = "HeartCounter"

[[migrations]]
tag = "v1"
new_sqlite_classes = ["HeartCounter"]
